---
import { AUTHOR, GITHUB_URL } from '../consts';
const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<span>&copy; {year} {AUTHOR}</span>
		<a href="/rss.xml">RSS</a>
		<a href={GITHUB_URL} target="_blank" rel="noopener">GitHub</a>
	</div>
</footer>
<style>
	footer {
		border-top: 1px solid var(--border);
		margin-top: 4em;
		color: var(--text-muted);
		font-size: 0.85em;
	}
	.inner {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1.5em 1em;
		display: flex;
		gap: 1.5em;
		align-items: center;
	}
	.inner a {
		color: var(--text-muted);
		border-bottom: none;
	}
	.inner a:hover {
		color: var(--text);
		border-bottom: none;
	}
</style>
